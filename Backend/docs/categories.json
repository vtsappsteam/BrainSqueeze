{
  "/categories": {
    "get": {
      "summary": "Get all categories",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "limit",
          "in": "query",
          "description": "Number of categories per page",
          "required": false,
          "schema": {
            "type": "integer",
            "example": 10
          }
        },
        {
          "name": "page",
          "in": "query",
          "description": "Page number (starting from 1)",
          "required": false,
          "schema": {
            "type": "integer",
            "example": 1
          }
        }
      ],
      "tags": ["Categories"],
      "responses": {
        "200": {
          "description": "List of categories",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "page": {
                    "type": "integer",
                    "example": 1
                  },
                  "limit": {
                    "type": "integer",
                    "example": 5
                  },
                  "totalPages": {
                    "type": "integer",
                    "example": 1
                  },
                  "totalCategories": {
                    "type": "integer",
                    "example": 1
                  },
                  "content": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "1"
                        },
                        "name": {
                          "type": "string",
                          "example": "Istorija"
                        },
                        "totalQuestions": {
                          "type": "integer",
                          "example": 20
                        },
                        "engName": {
                          "type": "string",
                          "example": "History"
                        },
                        "totalCount": {
                          "type": "integer",
                          "example": 1
                        }
                      }
                    }
                  }
                },
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "1"
                    },
                    "name": {
                      "type": "string",
                      "example": "History"
                    }
                  }
                }
              }
            }
          }
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    },
    "post": {
      "summary": "Create a new category",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "tags": ["Categories"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["name", "engName"],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Istorija"
                },
                "engName": {
                  "type": "string",
                  "example": "History"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Category created successfully"
        },
        "400": {
          "description": "Bad request"
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    }
  },
  "/categories/withDifficulties": {
    "get": {
      "summary": "Get categories with question difficulties",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "limit",
          "in": "query",
          "description": "Number of categories per page",
          "required": false,
          "schema": {
            "type": "integer",
            "example": 10
          }
        },
        {
          "name": "page",
          "in": "query",
          "description": "Page number (starting from 1)",
          "required": false,
          "schema": {
            "type": "integer",
            "example": 1
          }
        },
        {
          "name": "filterName",
          "in": "query",
          "description": "Filter categories by name",
          "required": false,
          "schema": {
            "type": "string",
            "example": "Istorija"
          }
        },
        {
          "name": "sortBy",
          "in": "query",
          "description": "Sort field",
          "required": false,
          "schema": {
            "type": "string",
            "enum": [
              "id",
              "categoryName",
              "engName",
              "totalQuestions",
              "totalQuestionsEasy",
              "totalQuestionsMedium",
              "totalQuestionsHard"
            ],
            "example": "name"
          }
        },
        {
          "name": "order",
          "in": "query",
          "description": "Sort order",
          "required": false,
          "schema": {
            "type": "string",
            "enum": ["asc", "desc"],
            "example": "asc"
          }
        }
      ],
      "tags": ["Categories"],
      "responses": {
        "200": {
          "description": "List of categories with question difficulties",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "page": {
                    "type": "integer",
                    "example": 1
                  },
                  "limit": {
                    "type": "integer",
                    "example": 5
                  },
                  "totalPages": {
                    "type": "integer",
                    "example": 1
                  },
                  "totalCategories": {
                    "type": "integer",
                    "example": 1
                  },
                  "content": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "1"
                        },
                        "categoryName": {
                          "type": "string",
                          "example": "Istorija"
                        },
                        "totalQuestions": {
                          "type": "string",
                          "example": "20"
                        },
                        "totalQuestionsEasy": {
                          "type": "string",
                          "example": "5"
                        },
                        "totalQuestionsMedium": {
                          "type": "string",
                          "example": "10"
                        },
                        "totalQuestionsHard": {
                          "type": "string",
                          "example": "5"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    }
  },
  "/categories/{id}": {
    "get": {
      "summary": "Get category by ID",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "ID of the category to retrieve",
          "required": true,
          "schema": {
            "type": "string",
            "example": "1"
          }
        }
      ],
      "tags": ["Categories"],
      "responses": {
        "200": {
          "description": "Category details",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "example": "1"
                      },
                      "name": {
                        "type": "string",
                        "example": "History"
                      },
                      "totalQuestions": {
                        "type": "string",
                        "example": "20"
                      },
                      "engName": {
                        "type": "string",
                        "example": "History"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "401": {
          "description": "Unauthorized"
        },
        "404": {
          "description": "Bad request"
        }
      }
    },
    "put": {
      "summary": "Update category by ID",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "ID of the category to update",
          "required": true,
          "schema": {
            "type": "string",
            "example": "1"
          }
        }
      ],
      "tags": ["Categories"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Izmenjena Istorija"
                },
                "engName": {
                  "type": "string",
                  "example": "Updated History"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Successfully updated Category"
        },
        "400": {
          "description": "Bad request"
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    },
    "delete": {
      "summary": "Delete category by ID",
      "security": [
        {
          "bearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "ID of the category to delete",
          "required": true,
          "schema": {
            "type": "string",
            "example": "1"
          }
        }
      ],
      "tags": ["Categories"],
      "responses": {
        "200": {
          "description": "Category deleted successfully"
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    }
  }
}
