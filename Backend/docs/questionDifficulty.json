{
  "/difficulties": {
    "get": {
      "tags": ["Question Difficulty"],
      "summary": "Get all question difficulties",
      "description": "Retrieve a list of all question difficulties available in the system.",
      "responses": {
        "200": {
          "description": "A list of question difficulties",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "1"
                        },
                        "name": {
                          "type": "string",
                          "example": "Lako"
                        },
                        "minThreshold": {
                          "type": "integer",
                          "example": 50
                        },
                        "maxThreshold": {
                          "type": "integer",
                          "example": 75
                        },
                        "totalQuestions": {
                          "type": "string",
                          "example": "10"
                        },
                        "engName": {
                          "type": "string",
                          "example": "Easy"
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "content": [
                  {
                    "id": 1,
                    "name": "Lako",
                    "minThreshold": 50,
                    "maxThreshold": 75,
                    "totalQuestions": "10",
                    "engName": "Easy"
                  }
                ]
              }
            }
          }
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    },
    "post": {
      "tags": ["Question Difficulty"],
      "summary": "Create a new question difficulty",
      "description": "Add a new question difficulty to the system.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["name", "minThreshold", "maxThreshold", "engName"],
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Lako"
                },
                "minThreshold": {
                  "type": "string",
                  "example": "50"
                },
                "maxThreshold": {
                  "type": "string",
                  "example": "75"
                },
                "engName": {
                  "type": "string",
                  "example": "Easy"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Question difficulty created successfully"
        }
      },
      "400": {
        "description": "Bad request"
      },
      "401": {
        "description": "Unauthorized"
      }
    }
  },
  "/difficulties/{id}": {
    "get": {
      "tags": ["Question Difficulty"],
      "summary": "Get a question difficulty by ID",
      "description": "Retrieve details of a specific question difficulty using its ID.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "ID of the question difficulty to retrieve",
          "schema": {
            "type": "string",
            "example": "1"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Details of the question difficulty",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "example": "1"
                  },
                  "name": {
                    "type": "string",
                    "example": "Lako"
                  },
                  "minThreshold": {
                    "type": "integer",
                    "example": 50
                  },
                  "maxThreshold": {
                    "type": "integer",
                    "example": 75
                  },
                  "totalQuestions": {
                    "type": "string",
                    "example": "10"
                  },
                  "engName": {
                    "type": "string",
                    "example": "Easy"
                  }
                }
              },
              "example": {
                "id": 1,
                "name": "Lako",
                "minThreshold": 50,
                "maxThreshold": 75,
                "totalQuestions": 10,
                "engName": "Easy"
              }
            }
          }
        },
        "401": {
          "description": "Unauthorized"
        },
        "404": {
          "description": "Question difficulty not found"
        }
      }
    },
    "put": {
      "tags": ["Question Difficulty"],
      "summary": "Update a question difficulty by ID",
      "description": "Update the details of a specific question difficulty using its ID.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "ID of the question difficulty to update",
          "schema": {
            "type": "string",
            "example": "1"
          }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Lako"
                },
                "minThreshold": {
                  "type": "string",
                  "example": "50"
                },
                "maxThreshold": {
                  "type": "string",
                  "example": "75"
                },
                "engName": {
                  "type": "string",
                  "example": "Easy"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Question difficulty updated successfully"
        },
        "400": {
          "description": "Bad request"
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    },
    "delete": {
      "tags": ["Question Difficulty"],
      "summary": "Delete a question difficulty by ID",
      "description": "Remove a specific question difficulty from the system using its ID.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "ID of the question difficulty to delete",
          "schema": {
            "type": "string",
            "example": "1"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Question difficulty deleted successfully"
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    }
  }
}
