  "/questions/import": {
    "post": {
      "summary": "Import questions from Excel or CSV",
      "description": "Import questions from an Excel or CSV file.",
      "tags": ["Questions"],
      "requestBody": {
        "required": true,
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string",
                  "format": "binary",
                  "description": "Excel or CSV file to upload"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Questions imported successfully."
        },
        "400": {
          "description": "Bad request."
        },
        "401": {
          "description": "Unauthorized."
        }
      }
    }
  },
  "/questions/quizResults": {
    "post": {
      "summary": "Submit quiz results (external)",
      "description": "Submit the results of a quiz attempt.",
      "tags": ["Questions"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["questionId", "answeredCorrectly"],
                "properties": {
                  "questionId": {
                    "type": "string"
                  },
                  "answeredCorrectly": {
                    "type": "boolean"
                  }
                }
              }
            },
            "example": [
              {
                "questionId": "123",
                "answeredCorrectly": false
              },
              {
                "questionId": "123",
                "answeredCorrectly": true
              }
            ]
          }
        }
      },
      "responses": {
        "200": {
          "description": "Quiz results submitted successfully."
        },
        "400": {
          "description": "Bad request."
        },
        "401": {
          "description": "Unauthorized."
        }
      }
    }
  },
